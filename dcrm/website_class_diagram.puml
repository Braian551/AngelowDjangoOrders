@startuml
skinparam classAttributeIconSize 0

class Record {
    +id : bigint <<PK>>
    +created_at : datetime
    +first_name : varchar(50)
    +last_name : varchar(50)
    +email : varchar(100)
    +phone_number : varchar(15)
    +address : varchar(255)
    +city : varchar(50)
    +state : varchar(50)
    +zip_code : varchar(10)
    +__str__()
}

class SignUpForm <<UserCreationForm>>
class RecordForm <<ModelForm>>

class WebsiteViews {
    +home()
    +login_user()
    +logout_user()
    +register_user()
    +customer_record()
    +delete_record()
    +update_record()
    +paginate_records()
}

RecordForm ..> Record : usa
WebsiteViews ..> Record : CRUD
WebsiteViews ..> SignUpForm : registro
WebsiteViews ..> RecordForm : edicion

@enduml
